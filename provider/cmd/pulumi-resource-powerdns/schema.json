{
    "name": "powerdns",
    "version": "0.0.1",
    "resources": {
        "powerdns:index:Random": {
            "properties": {
                "length": {
                    "type": "integer"
                },
                "result": {
                    "type": "string"
                }
            },
            "required": [
                "length",
                "result"
            ],
            "inputProperties": {
                "length": {
                    "type": "integer"
                }
            },
            "requiredInputs": [
                "length"
            ]
        },
        "powerdns:index:PDNSRecord": {
            "properties": {
                "zone":{
                    "type": "string"
                },
                "name":{
                    "type": "string"
                },
                "type":{
                    "type": "string"
                },
                "ttl":{
                    "type": "integer"
                },
                "records":{
                    "type": "array",
                    "items":{
                        "type": "string"
                    }
                },
                "set_ptr":{
                    "type": "boolean",
                    "description": "For A and AAAA records, if true, create corresponding PTR."
                }
            },
            "required": [
                "zone",
                "name",
                "type",
                "ttl",
                "records"
            ]
        },
        "powerdns:index:PDNSZone": {
            "properties": {
                "name":{
                    "type": "string"
                },
                "kind":{
                    "type": "string"
                },
                "account":{
                    "type": "string",
                    "default": "admin"
                },
                "nameservers":{
                    "type": "array",
                    "items":{
                        "type": "string"
                    }
                },
                "masters":{
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "soa_edit_api":{
                    "type": "string"
                }
            },
            "required": [
                "name",
                "kind"
            ]
        }
    },
    "language": {
        "csharp": {
            "packageReferences": {
                "Pulumi": "3.*"
            }
        },
        "go": {
            "generateResourceContainerTypes": true,
            "importBasePath": "github.com/nextpart/pulumi-powerdns-native/sdk/go/powerdns"
        },
        "nodejs": {
            "dependencies": {
                "@pulumi/pulumi": "^3.0.0"
            }
        },
        "python": {
            "requires": {
                "pulumi": ">=3.0.0,<4.0.0"
            }
        }
    }
}
